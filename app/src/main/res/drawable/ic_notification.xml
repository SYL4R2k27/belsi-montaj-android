    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#FFFFFFFF">

    <!-- Bold "B" monogram, 4-22 vertical, 4-18 horizontal -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M5,4 h7 a4,4 0 0 1 0,8 h-2 v-2 h2 a2,2 0 0 0 0,-4 h-3 v14 h-2 z M9,11 h3 a4,4 0 0 1 0,8 h-7 v-2 h7 a2,2 0 0 0 0,-4 h-3 z" />
</vector>
